FROM ricejasonf/cppdock:linux_x64 AS base_image
  RUN apt-get update -yq && apt-get install -yq nodejs npm

FROM base_image AS build_binaryen
  WORKDIR /opt/src
  RUN git clone --depth=1 --branch version_125 \
    https://github.com/WebAssembly/binaryen.git
  WORKDIR /opt/build
  RUN cmake -DCMAKE_TOOLCHAIN_FILE=/opt/toolchain.cmake \
            -DBUILD_TESTS=OFF \
            -DINSTALL_PREFIX=/opt/install \
            /opt/src/binaryen && \
    make -j$(nproc) && make install

FROM base_image AS build_emscripten
  WORKDIR /opt/src
  RUN git clone --depth=1 --branch 4.0.20 \
    https://github.com/emscripten-core/emscripten
  WORKDIR /opt/src/emscripten
  RUN ./tools/maint/create_entry_points.py && \
      ./tools/install.py /opt/install/emscripten
  
FROM base_image
  COPY cppdock /usr/local/bin/
  COPY recipes/ /root/.cppdock_recipes
  COPY toolchain/emscripten.cmake /opt/toolchain.cmake
  COPY --from=build_binaryen /opt/install/ /opt/sysroot
  COPY --from=build_emscripten /opt/install/ /opt/sysroot
  WORKDIR /opt/sysroot/emscripten
  RUN ./emcc --generate-config && ./emcc --check
