def get_dev_compose_file(config: Config):
    result = get_dev_compose_object(config)
    return json.dumps(remove_none(result), indent=2, separators=(',', ': '))

def get_dev_compose_object(config: Config):
    platforms: List[PlatformSpec] = get_all_platforms(config)
    service_confs = [get_dev_compose_file_service(platform)
                     for platform in platforms
                     if isinstance(platform, ServiceSpec)]
    secrets = config.secrets
    secrets.update(get_secret_files());

    services = {}
    volumes = {}
    for x in service_confs:
        services.update(x['service'])
        secrets.update(x.get('secrets', {}))
        volumes.update(x.get('volumes', {}))

    return {
        'version': '3.1',
        'services': services,
        'volumes': volumes,
        'secrets': secrets
    }

def get_dev_compose_file_service(platform: ServiceSpec):
    config = platform.config
    if is_platform_service(platform):
        return platform.get_dev_compose_file_service_service()

    # generate service definition for dev images

    service_name = get_service_name(platform)
    image_tag = get_build_tag_name(platform)
    image_tag = get_registry_tag(config, image_tag)
    target = get_dev_service_target(platform)
    build_type = get_build_type(platform)

    command = "cppdock init_dev_service {build_type} {target}".format(
            build_type = build_type,
            target = target)

    web_root: Optional[str] = None
    if platform.web_root:
        web_root = "web_root:{0}".format(platform.web_root)

    src_mount_path = get_build_source_path(config)
    src_mount = '{src_mount_path}:/opt/src:ro'.format(src_mount_path = src_mount_path)
    domain = platform.domain
    environment = { 'DOMAIN': domain }
    environment.update(platform.environment)
    secrets = platform.secrets
    build_volume_name = platform.name + '_build'

    return {
        'service': {
            service_name: {
                'image': image_tag,
                'command': command,
                'environment': environment,
                'secrets': secrets,
                'volumes': [
                    src_mount,
                    '{}:/opt/build'.format(build_volume_name),
                    web_root
                ]
            }
        },
        'volumes': {
            build_volume_name: None
        }
    }

def default_compose_file_service(platform: PlatformSpec):
    result: dict = {}
    result.update(platform.__dict__)
    platform_name = platform.name
    del result['type']
    return {
        'service': {
            platform_name: result
        }
    }

