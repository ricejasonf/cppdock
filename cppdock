class SourceSpec(SpecBase):
    def __init__(self, obj: JsonDict = {}):
        self.path: Optional[str] = None
        self.allow_sync: bool = False
        self.sync_dirs: Optional[List[str]] = None
        super().__init__(obj)

    @staticmethod
    def create(obj: JsonDict):
        type = obj.get('type')
        if type is None:
            type = 'git' if ('repo' in obj) else 'mount'
        match type:
            case 'mount':
                return MountSourceSpec(obj)
            case 'git':
                return GitSourceSpec(obj)

class MountSourceSpec(SourceSpec):
    def __init__(self, obj: JsonDict = {}):
        # Host machine path to mount volume to /opt/src
        super().__init__(obj)
        self.path = self.path or "."

class GitSourceSpec(SourceSpec):
    def __init__(self, obj: JsonDict):
        self.tag: str = 'master'
        # A filename for a bash script to initialize the source code
        # This does some weird file loading and appending junk.
        self.init: Optional[str] = None
        # Use a repo name to generate script instead of `init`.
        self.repo: Optional[str] = None
        super().__init__(obj)
        self.path: str = self.path or './source'
        self.allow_sync = (self.path is not None and
                           self.allow_sync is None)

class Config(SpecBase):
    def __init__(self, obj: JsonDict):
        # Specify build type (The default is set to different
        #                     values depending on context)
        self.default_build_type: str = 'debug'
        # Make a nice name for the current project.
        self.project_name: str
        # Specify docker image for cppdock stuff. (not locked)
        self.cppdock_image: str = "ricejasonf/cppdock"
        # Define various platforms.
        self.platforms: dict[str, PlatformSpec] = {}
        # Define how to manage source code for the project
        # mounting to /opt/src in the container
        # (which is the current directory by default.)
        self.source: SourceSpec
        # Support specifying remote machines to build on.
        # TODO Make MachineSpec for elements of this.
        self.machine_list: List[Any] = []
        # Local Docker registry to use
        self.registry: str = '127.0.0.1:5000'
        # Docker compose service defaults (e.g. domain_name)
        self.service_defaults: JsonDict = {}
        # Top level secrets for docker compose
        # Do not put actual secrets here.
        self.secrets: dict[str, Any] = {}

        super().__init__(obj)
        cppdock = self.orig_obj['cppdock']
        self.project_name = cppdock.get('name')
        self.merge(cppdock)
        self.source: SourceSpec = SourceSpec.create(obj.get('source', {}))
        for platform_name, platform_obj in obj['platforms'].items():
            self.platforms[platform_name] = PlatformSpec.create(
                    self, platform_name, platform_obj)
        self.machine_list = get_machine_list(self.orig_obj)

def remove_none(obj):
  if isinstance(obj, (list, tuple, set)):
    return type(obj)(remove_none(x) for x in obj if x is not None)
  elif isinstance(obj, dict):
    return type(obj)((remove_none(k), remove_none(v))
      for k, v in obj.items() if k is not None)
  else:
    return obj

