def load_config_file_with_args(args):
    json_file_path = args.json_file_path
    return load_config_file(json_file_path)

def load_config_file(json_file_path: str) -> Config:
    config_paths: List[str] = []
    config_paths.insert(0, json_file_path)
    config_obj = load_config_file_json(json_file_path)

    config_obj = lock_config_file_deps(config_obj)
    write_config_file(config_obj, json_file_path)

    config_obj = normalize_config_paths(config_obj)
    config_obj = merge_base_config(config_obj, config_paths)

    return Config(config_obj)

def load_config_file_json(json_file_path):
    if os.path.isdir(json_file_path):
        json_file_path = os.path.join(json_file_path, 'cppdock.json')

    if not os.path.isfile(json_file_path):
        raise ValueError('Config file not found: ' + json_file_path)
    stream = open(json_file_path, 'r')
    config_json = json.load(stream, object_pairs_hook=OrderedDict)

    # validate
    assert "cppdock" in config_json,             "Config must have cppdock section"
    assert "name" in config_json["cppdock"],     "Config must have 'name' in cppdock section"

    return config_json

def normalize_config_paths(config_obj):
    # this should happen after writing revision locks
    cppdock = config_obj["cppdock"]
    source = config_obj.get("source")
    if "base_config" in cppdock:
        cppdock["base_config"] = os.path.abspath(cppdock["base_config"])
    if source and "path" in source and source["path"] != None:
        source["path"] = os.path.abspath(source["path"])

    return config_obj

def write_config_file(config_obj, json_file_path):
    json_str = json.dumps(config_obj, indent=2, separators=(',', ': '))
    try:
        with open(json_file_path, 'w') as fh:
            fh.write(json_str)
            fh.write('\n')
    except:
        warnings.warn('WARNING: Unable to write to json file')

def merge_base_config(config_obj, config_paths):
    if "base_config" not in config_obj["cppdock"]:
        return config_obj
    base_config_path = os.path.abspath(config_obj["cppdock"]["base_config"])
    del config_obj["cppdock"]["base_config"]
    config_paths.insert(0, base_config_path)
    base_config = load_config_file_json(base_config_path)

    # merge cppdock section
    cppdock_section = {}
    cppdock_section.update(base_config["cppdock"])
    cppdock_section.update(config_obj["cppdock"])
    config_obj["cppdock"] = cppdock_section

    # only include platforms specified in current config_obj
    platforms = {}

    for platform_name in config_obj.get("platforms", {}):
        platforms[platform_name] = merge_platform_config(platform_name, base_config, config_obj)

    config_obj["platforms"] = platforms
    return config_obj

def merge_platform_config(platform_name, base_config, config_obj):
    result = {}
    platform = config_obj["platforms"].get(platform_name, {})
    base_platform = base_config.get("platforms", {}).get(platform_name, {})

    result.update(base_platform)
    result.update(platform)
    if config_obj.get('deps') or base_config.get('deps'):
        result["deps"] = []
        result["deps"] += base_platform.get("deps", [])
        result["deps"] += platform.get("deps", [])
    return result

def lock_config_file_deps(config_obj):
    if 'platforms' not in config_obj:
        return config_obj
    for platform, settings in config_obj['platforms'].items():
        check_base_image_conflict(settings)

        for stage in settings.get('deps', []):
            if not isinstance(stage, list):
                raise "Each stage in 'deps' must be an array."
            for item in stage:
                item = lock_item_json(item)

    return config_obj

def lock_item_json(item):
    current_sha = get_current_sha_with_comment(item)
    item.update(revision = current_sha)

    return item

def get_current_sha_with_comment(item):
    repo = item['name']
    tag = item.get('tag')
    source = item.get('type', (item.get('source')))

    if 'revision' in item:
        return item['revision']
    else:
        if source == 'docker':
            tag = tag or 'latest'
            repo_tag = repo + ":" + tag

            try:
                # pull the image from the registry to get the RepoDigest
                subprocess.check_output(['docker', 'pull', repo_tag])
            except:
                raise RuntimeError("Unable to pull docker image from registry: " + repo_tag )

            try:
                inspect_result =  subprocess.check_output(['docker', 'inspect', repo_tag])
                digest = json.loads(inspect_result)[0]['RepoDigests'][0].split('@')[1]
            except:
                raise RuntimeError("Unable to get SHA from docker image")

            return digest
        else:
            tag = normalize_branch_name(tag)
            lines = subprocess.check_output(['git', 'ls-remote', normalize_repo_name(repo)]).splitlines()
            for line in lines:
                line_str = line.decode('utf-8')
                if line_str.endswith(tag):
                    return line_str[0:40]
            raise RuntimeError("Unable to get SHA from remote git repository")

def normalize_repo_name(name):
    return default_dep_path + name;

def normalize_branch_name(name):
    if name == None or len(name) == 0 or name == 'HEAD':
        return 'HEAD'
    elif name.startswith('refs/'):
        return name
    else:
        return "refs/heads/" + name

