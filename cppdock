def make_deps_dockerfile(platform: PlatformSpec):
    base_image = get_base_tag_name(platform)
    deps_stages = ''
    deps_imports = ''

    build_type = get_build_type(platform)
    target = get_dev_service_target(platform)

    service_init = get_service_init(platform)
    copy_service_init = ''
    if service_init and service_init.startswith('/opt/'):
        copy_service_init = "RUN cp {} /opt/service_init".format(
                service_init)
    else:
        copy_service_init = "COPY {} /opt/service_init".format(
                service_init)

    copy_toolchain = ''
    if platform.toolchain_file.startswith('/opt/'):
        copy_toolchain = """
    RUN cp {} /opt/toolchain.cmake""".format(platform.toolchain_file)
    else:
        copy_toolchain = """
    COPY {} /opt/toolchain.cmake""".format(platform.toolchain_file)

    for deps in platform.deps_stages:
        deps_stages += " ".join([make_deps_stage(base_image, platform, deps)])
        deps_imports += make_deps_import(deps[-1])

    # FIXME I think it is incorrect to use CMD here since init_dev_service calls the
    #       script for running the main image (not this dependency.)
    return """
{deps_stages}
FROM {base_image}
{deps_imports}
    {copy_service_init}{copy_toolchain}
    WORKDIR /opt/build
    CMD ["cppdock", "init_dev_service", "--shell-only", "{build_type}", "{target}"]
""".format(deps_stages              = deps_stages,
           base_image               = base_image,
           deps_imports             = deps_imports,
           copy_service_init        = copy_service_init,
           copy_toolchain           = copy_toolchain,
           build_type               = build_type,
           target                   = target)
    return

def make_deps_stage(base_image, platform: PlatformSpec, deps: list[DepSpec]):
    if len(deps) == 0:
        return ''

    build_image = base_image

    # Only DockerDepSpec does not use make_install_dep.
    docker_image_digest = get_stage_docker_image_digest(deps)
    if docker_image_digest is not None:
      build_image  = docker_image_digest
      install_deps = ''
    else:
      install_deps = " ".join([make_install_dep(platform, dep) for dep in deps])

    platform_label = deps[-1].get_platform_label()

    return """
FROM {0} AS build_{2}_{1}
    WORKDIR /usr/local/src
    {3}
""".format(build_image, platform.name, platform_label, install_deps)

def get_stage_docker_image_digest(stage_deps: List[DepSpec]):
    if len(stage_deps) == 1:
        for dep in stage_deps:
            if isinstance(dep, DockerDepSpec):
                repo_name = dep.name
                revision = dep.revision
                return f'{repo_name}@{revision}'
    return None

def make_install_dep(platform: PlatformSpec, dep: DepSpec):
    if dep._is_overlay_mounted:
        return ''
    revision = dep.revision
    repo_name = dep.name
    if isinstance(dep, DockerDepSpec):
        revision = dep.revision
        dest_dir = platform.dest_dir;
        return f"""
    COPY --from={repo_name}@{revision} /opt/install {dest_dir}
    COPY --from={repo_name}@{revision} /opt/install /opt/install"""

    if revision is None:
        return ''

    assert isinstance(dep, GitHubDepSpec)

    # Copy user specified recipe to keep changes to arbitrary recipe files
    # from invalidating the entire set of build stages for every dependency.
    copy_local_recipe = ''
    if dep.recipe_script is not None:
        if dep.recipe_script.startswith('/opt/'):
            copy_local_recipe = """
    RUN cp {} /opt/recipe_script""".format(dep.recipe_script)
        else:
            copy_local_recipe = """
    COPY {} /opt/recipe_script""".format(dep.recipe_script)

    # Copy local toolchain or copy container toolchain to /opt/toolchain.cmake
    copy_local_toolchain = ''
    if dep.toolchain_file is not None:
        if dep.toolchain_file.startswith('/opt/'):
            copy_local_recipe = """
    RUN cp {} /opt/toolchain.cmake""".format(dep.toolchain_file)
        else:
            copy_local_recipe = """
    COPY {} /opt/toolchain.cmake""".format(dep.toolchain_file)

    return """{3}
    {4}
    RUN cppdock install_dep {0} {1} {2}""".format(
            platform.name, revision, repo_name,
            copy_local_recipe, copy_local_toolchain)

def make_deps_import(dep: DepSpec):
    return """
    COPY --from=build_{1}_{0} /opt/install/ {2}""".format(
            dep.platform.name, dep.get_platform_label(), dep.dest_dir)

def get_run_options_mount_source(config: Config):
