def get_run_options_mount_build(platform: PlatformSpec):
    build_dir = platform.build_dir
    if build_dir_mount := platform.build_dir_mount:
        return ['--mount',
                f"type=bind,source={build_dir_mount},target={build_dir}"]

    volume_name = platform.get_volume_name()
    return ['--volume', f"{volume_name}:{build_dir}"]

def get_run_options_mount_install(platform: PlatformSpec, install_dir):
    return ['--mount', f"type=bind,source={install_dir},target=/opt/install"]

def run_build_image(platform: PlatformSpec, target,
                    shell, shell_only, privileged, ports_arg):
    tag_name = get_build_tag_name(platform)

    cmd = []
    shell_op = '--shell' if shell else None;
    shell_only_op = '--shell-only' if shell_only else None;
    privileged_op = '--privileged' if privileged else None;
    if target:
        build_type = get_build_type(platform)
        cmd = ["cppdock", "init_dev_service", build_type, target, shell_op,
               shell_only_op, '--no-service']
    mount_build = get_run_options_mount_build(platform)
    mount_src = get_run_options_mount_source(platform.config)

    # FIXME This is incomplete and not used.
    #       The idea was to specify mount options and then use something like
    # https://serverfault.com/questions/841238/how-to-use-overlayfs-with-docker-volumes
    dep_mounts = [dep.create_mount_option(index)
                  for index, dep in platform.enumerate_deps()]

    subprocess.call(remove_none(['docker', 'run', '--rm', '-it', ports_arg, privileged_op]
                                 + mount_src
                                 + mount_build
                                 + [ tag_name ]
                                 + cmd))

# Used by command_release.
def run_build_image_install(platform: PlatformSpec, install_dir):
    config = platform.config
    tag_name = get_build_tag_name(platform)
    src_path = get_build_source_path(config)
    target = platform.release_target
    build_type = get_build_type(platform)

    cmd = ["cppdock", "init_dev_service", build_type, target, '--no-service']

    mount_build = get_run_options_mount_build(platform)
    mount_src = get_run_options_mount_source(config)
    mount_install = get_run_options_mount_install(platform, install_dir)
    returncode = subprocess.call(remove_none(['docker', 'run', '--rm']
                                 + mount_src
                                 + mount_build
                                 + mount_install
                                 + [ tag_name ]
                                 + cmd))
    if returncode != 0:
        sys.exit(1)

def get_install_path(platform: PlatformSpec):
    return '/tmp/{}.install'.format(get_release_tag_name(platform))

def create_install_dir(platform: PlatformSpec):
    path = get_install_path(platform)
    cmd = ['mkdir', '-p', path]

    if is_cluster_mode(platform.config):
        name = get_master_machine_name(platform.config)
        cmd = ['docker-machine', 'ssh', name] + cmd

    p = subprocess.Popen(cmd, stdin = subprocess.PIPE)
    p.communicate()

    if p.returncode != 0:
        raise RuntimeError(
            'Failed to create install directory: {}'.format(path))
    return path

def remove_install_dir(config: Config, path):
    assert path.startswith('/tmp/') and path.endswith('.install'), "Must only delete valid install path"
    if not os.path.isdir(path):
        return
    cmd = ['rmdir', path]

    if is_cluster_mode(config):
        name = get_master_machine_name(config)
        cmd = ['docker-machine', 'ssh', name] + cmd

    p = subprocess.Popen(cmd, stdin = subprocess.PIPE)
    p.communicate()

    if p.returncode != 0:
        raise RuntimeError(
            'Failed to remove install directory: {}'.format(path))
    return path

def clean_install_files(platform: PlatformSpec, install_dir):
    # We have to delete the installs files in a container
    # because the cppdock user wont have to permissions
    if not os.path.isdir(install_dir):
        return
    base_image = platform.config.cppdock_image
    assert install_dir.startswith('/tmp/') and install_dir.endswith('.install'), "Must only delete valid install path"
    cmd = ['/bin/bash', '-c', 'rm -rf /opt/install/*']
    mount_install = get_run_options_mount_install(platform, install_dir)
    cmd = remove_none(['docker', 'run', '--rm']
                      + mount_install
                      + [ base_image ]
                      + cmd)
    subprocess.call(cmd)

