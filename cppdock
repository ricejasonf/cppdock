type JsonDict = dict[str, Any]

class SpecBase:
    def __init__(self, obj: JsonDict = {}):
        self.orig_obj: dict = {}
        self.merge(obj)

    def merge(self, obj: JsonDict):
        self.orig_obj |= obj
        for attr, value in obj.items():
            if hasattr(self, attr):
                setattr(self, attr, value)

class DepSpec(SpecBase):
    # Indicate if this is a volume or bind mount type
    # that must be overlay mounted on its dest_dir.
    _is_overlay_mounted:bool = False

    @staticmethod
    def create(platform: 'PlatformSpec', dep: JsonDict):
        if 'type' not in dep and 'source' in dep:
            warnings.warn('"source" property for dep is deprecated.'
                          'use "type" instead',
                          DeprecationWarning)
            dep['type'] = dep['source']
            del dep['source']
        match dep.get('type', 'github'):
            case 'github': return GitHubDepSpec(platform, dep)
            case 'docker': return DockerDepSpec(platform, dep)
            case 'volume': return VolumeDepSpec(platform, dep)
            case 'mount': return MountDepSpec(platform, dep)

    def __init__(self, platform: 'PlatformSpec', obj: JsonDict):
        # A PlatformSpec
        self.platform: 'PlatformSpec' = platform
        # A nice name that serves as a default for DepSpecs (e.g. repo_name)
        self.name: str
        # DepSpec object (May be constructed by string)
        self.type: str = "github"
        # Some properties such as "revision" or "volume_name" are
        # propagated to DepSpec.
        # Git tag or branch name (also propagated to DepSpec.)
        self.tag: Optional[str] = None
        # Path of CMake toolchain file (if different from platform)
        self.toolchain_file: Optional[str] = None
        # Force specific file for recipe
        # (Copied from docker build env to /opt/recipe_script)
        self.recipe_script: Optional[str] = None
        # Location to copy from /opt/install
        self.dest_dir: Optional[str] = None
        # Lock to a revision and use as a unique label for build stages.
        # Use None to indicate that the dep is not part of a build stage
        # (e.g. a volume)
        self.revision: Optional[str] = None

        platform_defaults = {
            'toolchain_file': platform.toolchain_file,
            'recipe_script': platform.recipe_script,
            'dest_dir': platform.dest_dir
            }
        obj = platform_defaults | obj
        super().__init__(obj)
        assert isinstance(obj['name'], str)
        self.name = obj['name']

    # FIXME Do revisions ever have slashes?
    def get_platform_label(self: Self) -> str:
        return self.name.replace('/', '_')

    def create_mount_option(self, unique_id: int):
        return None


class GitHubDepSpec(DepSpec):
    def __init__(self, platform: 'PlatformSpec', obj: JsonDict):
        # Github tag or branch name
        self.tag: Optional[str] = None
        # Revision lock value (SHA Digest)
        self.revision: str

        super().__init__(platform, obj)
        self.revision = obj['revision']

class DockerDepSpec(DepSpec):
    def __init__(self, platform: 'PlatformSpec', obj: JsonDict):
        # Additional image tag name
        self.tag: Optional[str] = "latest"
        # Revision lock value (SHA256 Digest)
        # An empty string is accepted for local images to
        # be specified by "{name}:{tag}".
        self.revision: str

        super().__init__(platform, obj)
        self.revision = obj['revision']

    def get_build_stage_spec(self):
        assert self.revision is not None
        if self.revision == "":
            return '{0}:{1}'.format(name, tag)
        else:
            return '{0}@{1}'.format(name, revision)

class VolumeDepSpec(DepSpec):
    _is_overlay_mounted:bool = True

    def __init__(self, platform: 'PlatformSpec', obj: JsonDict):
        # Docker local volume name
        self.volume_name: Optional[str] = None

        if 'volume_name' not in obj:
            obj['volume_name'] = obj['name']
        super().__init__(platform, obj)

class MountDepSpec(DepSpec):
    _is_overlay_mounted:bool = True

    def __init__(self, platform: 'PlatformSpec', obj: JsonDict):
        # Local path to mount volume to
        self.mount_path: Optional[str] = None

        super().__init__(platform, obj)
        self.mount_path = obj['mount_path']

    def create_mount_option(self, unique_id: int):
        # Make a target path that `cppdock init_dev_service`
        # will find and do the overlay mount thing.
        dest_dir = f'/opt/.cppdock_overlay_mounts/{unique_id}'
        return ['--mount', f'type=bind,source={self.mount_path},target={dest_dir}']

class PlatformSpec(SpecBase):
    def __init__(self, config: 'Config', name: str, obj: JsonDict):
        self.config: 'Config' = config
        # Specify type.
        self.type: Optional[str] = None
        # Specify the name of the platform (via the key of the object.)
        self.name: str = name
        # List of list of deps for stages
        self.deps_stages: List[List[DepSpec]] = []
        # Name of docker image to base off of
        self.base_image: Optional[str] = None
        # Path to Dockerfile to create base image instead of using base_image
        self.base_image_dockerfile: Optional[str] = None
        # Path to sysroot directory
        self.sysroot: str = "/opt/sysroot"
        # Specify default paths for toolchain_file and recipe_script.
        # If prefixed with /opt/ then the file is copied from
        # within the container.
        # (copies to /opt/toolchain.cmake and /opt/recipe_script)
        self.toolchain_file: Optional[str] = None
        self.recipe_script: Optional[str] = None
        # Path of build directory in container
        self.build_dir: str = "/opt/build"
        # Path of build host directory to bind mount (if any)
        self.build_dir_mount: Optional[str] = None
        # File to copy for command to run for container
        # (which copies to /opt/init_service)
        self.service_init_script: str = '/opt/cppdock/recipes/default'
        self.dev_service_target: str = 'check'
        self.service_cmd: List[str] = ['cmake', '--build', '/opt/build'
                                  '--self.target', "check"]
        # Location to copy from /opt/install
        self.dest_dir: str = "/opt/sysroot"
        # Name of docker tag to use when pushing release image.
        self.push_tag: Optional[str] = None  # TODO implement use of this
        # Specify build_type and release target
        # for use with `cppdock init_service`
        self.build_type: Optional[str] = None
        self.release_target: str = 'install'

        deps_list = obj.get('deps', [])
        if 'deps' in obj:
            del obj['deps']
        super().__init__(obj)
        self.name = name
        for deps_stage in deps_list:
            cur_stage = []
            for dep in deps_stage:
                cur_stage.append(DepSpec.create(self, dep))
            self.deps_stages.append(cur_stage)
        if 'service_defaults' in obj:
            self.service_defaults = obj.get('service_defaults', {})

    @staticmethod
    def create(config: 'Config', name: str, obj: JsonDict):
        type = obj.get('type')
        match type:
            case 'linux_x64':
                default_obj = {
                    'base_image': 'ricejasonf/cppdock:linux_x64',
                    'toolchain_file': '/opt/cppdock/toolchains/linux_x64.cmake',
                    'service_init_script': '/opt/cppdock/recipes/default'
                }
                return PlatformSpec(config, name, default_obj | obj)
            case 'emscripten':
                default_obj = {
                    'base_image': 'ricejasonf/cppdock:emscripten',
                    'toolchain_file': '/opt/cppdock/toolchains/emscripten.cmake',
                    'service_init_script': '/opt/cppdock/recipes/default-emscripten'
                }
                return PlatformSpec(config, name, default_obj | obj)
            case 'nginx_proxy':
                return NginxProxySpec(config, name, obj)
            case 'postgres':
                return PostgresSpec(config, name, obj)
            case _:
                return PlatformSpec(config, name, obj)

    def get_volume_name(self, build_type = None):
        if build_type == None:
            build_type = get_build_type(self).lower()
        return get_image_tag_name(self, build_type)

    # Return an enumerated list of all deps.
    def enumerate_deps(self):
        return enumerate([x for xs in self.deps_stages for x in xs])

